---
import { company, heroMedia, intake} from '../data/site';

const hasVideo = Boolean(heroMedia.video);

// Each line reveals independently, so the three "More" lines land in sequence
// and the turn arrives last. The fourth line is the one that does the work -
// it names what everyone else sells, which is what makes the first three
// specific rather than generic agency copy.
const lines = [
  [{ t: 'More' }, { t: 'bookings.', accent: true }],
  [{ t: 'More' }, { t: 'leads.', accent: true }],
  [{ t: 'More' }, { t: 'sales.', accent: true }],
];

// The closing line cycles through the sectors we have actually delivered in,
// so "your industry" becomes the visitor's industry. Deliberately not a link -
// a click target that changes under the cursor is hostile.
const industries = [
  'real estate.',
  'aesthetics.',
  'dental.',
  'food service.',
  'insurance.',
  'fitness.',
  'automotive.',
  'travel.',
];
---

<!-- Fixed backdrop. Lives outside the hero so the terrain stays with you all
     the way down the page instead of scrolling away after one screen. -->
<div id="stage" class="pointer-events-none fixed inset-0 -z-10" aria-hidden="true">
  <canvas id="hero-canvas" class="absolute inset-0 h-full w-full transition-opacity duration-1000"></canvas>
  <canvas id="hero-gl" class="absolute inset-0 hidden h-full w-full"></canvas>
  <div id="hero-spot" class="absolute inset-0 opacity-0"></div>
</div>

<section
  id="hero"
  class="hero relative isolate flex min-h-[100svh] flex-col justify-end overflow-hidden px-6 pb-12 pt-32 sm:px-10 lg:px-14 lg:pb-14"
>
  {
    hasVideo && (
      <video
        id="hero-video"
        class="absolute inset-0 -z-20 h-full w-full object-cover opacity-0 transition-opacity duration-1000"
        poster={heroMedia.poster || undefined}
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
        tabindex="-1"
      >
        <source src={heroMedia.video} type="video/mp4" />
      </video>
    )
  }

  <!-- Scrim guarantees headline contrast whatever the motion layer is doing. -->
  <div id="hero-scrim" class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true"></div>

  <div id="hero-content" class="relative mx-auto w-full max-w-[90rem]">
    <div class="hero-line flex items-center gap-4" style="--i:0">
      <span class="h-px w-12 bg-clay-500" aria-hidden="true"></span>
      <p class="label text-ink-500">{company.serviceArea}</p>
    </div>

    <h1 class="display mt-8 text-[clamp(2.6rem,7.8vw,7rem)]">
      {
        lines.map((line, li) => (
          <span class="hero-line block" style={`--i:${li + 1}`}>
            {line.map((part, pi) => (
              <>
                {pi > 0 && ' '}
                <span class={part.accent ? 'italic text-clay-500' : ''}>{part.t}</span>
              </>
            ))}
          </span>
        ))
      }
      <!-- Screen readers get the plain sentence; the rotator is decorative. -->
      <span class="hero-line mt-2 block" style="--i:4">
        <span class="sr-only">Be the best in your industry.</span>
        <span aria-hidden="true" class="flex flex-wrap items-baseline gap-x-[0.3em]">
          <span class="text-ink-500">Be the best in</span>
          <span id="industry-rotator" class="relative inline-block overflow-hidden align-bottom">
            <span id="industry-track" class="block will-change-transform">
              {industries.map((w) => <span class="block whitespace-nowrap italic text-clay-500">{w}</span>)}
            </span>
          </span>
        </span>
      </span>
    </h1>

    <div class="mt-10 grid gap-8 border-t rule pt-8 lg:grid-cols-[1fr_auto] lg:items-start">
      <p class="hero-line max-w-2xl text-lg leading-relaxed text-ink-700 sm:text-xl" style="--i:5">
        A growth studio in the Philippines, here to make you the one they call first. Ads, recruitment, AI response,
        social, websites and SEO - run as one system by one team, and judged only on what it books, captures and
        closes.
      </p>

      <div class="hero-line flex flex-col gap-3 sm:flex-row lg:shrink-0" style="--i:6">
        <a
          href="/apply/"
          class="group inline-flex items-center justify-center gap-2.5 rounded-full bg-ink-900 px-8 py-4 text-sm font-semibold text-bone-50 transition-all hover:-translate-y-0.5 hover:bg-clay-500"
        >
          {intake.ctaPrimary}
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
        <a
          href="/case-studies/"
          class="inline-flex items-center justify-center rounded-full border rule px-8 py-4 text-sm font-semibold text-ink-900 backdrop-blur-sm transition-colors hover:border-ink-900"
        >
          See the numbers
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  /* ---- Layers ---------------------------------------------------------- */
  #hero-spot {
    background: radial-gradient(
      42rem 42rem at var(--mx, 50%) var(--my, 40%),
      color-mix(in oklab, var(--color-clay-500) 26%, transparent),
      transparent 62%
    );
    transition: opacity 1.2s ease;
  }

  #hero-scrim {
    background:
      linear-gradient(to top, var(--color-bone-50) 2%, color-mix(in oklab, var(--color-bone-50) 55%, transparent) 42%, transparent 78%),
      radial-gradient(70% 60% at 22% 62%, color-mix(in oklab, var(--color-bone-50) 72%, transparent), transparent 70%);
  }

  /* ---- Kinetic type ---------------------------------------------------- */
  /* Each line rises out of its own clip. Staggered by --i. */
  .hero-line {
    animation: hero-rise 1.1s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    animation-delay: calc(var(--i, 0) * 110ms + 120ms);
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(1.1em);
      clip-path: inset(0 0 100% 0);
    }
    to {
      opacity: 1;
      transform: none;
      clip-path: inset(-30% -20% -30% -20%);
    }
  }

  /* Scroll hand-off: content drifts and fades as the hero leaves. */
  #hero-content {
    will-change: transform, opacity;
  }

  /* Rotator. Height is set in JS from the measured line box so the sentence
     never reflows, and the track slides by whole lines. */
  #industry-rotator {
    height: 1em;
  }
  #industry-track {
    transition: transform 0.72s cubic-bezier(0.76, 0, 0.24, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    #industry-track {
      transition: none;
    }
  }

  /* Once WebGL is live the 2D field steps back to a faint texture over it. */
  #stage.has-gl #hero-canvas {
    opacity: 0.28;
  }
  #stage.has-gl #hero-gl {
    display: block;
  }

  /* ---- Progressive enhancement floors ---------------------------------- */
  :global(html.no-js) #hero-canvas,
  :global(html.no-js) #hero-spot {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-line {
      animation: none;
    }
    #hero-spot {
      display: none;
    }
  }
</style>

<script is:inline>
  // Industry rotator.
  (() => {
    const box = document.getElementById('industry-rotator');
    const track = document.getElementById('industry-track');
    if (!box || !track) return;

    const items = [...track.children];
    if (items.length < 2) return;

    // Width is set per word so the line does not jitter as lengths change.
    const sizeTo = (i) => {
      const w = items[i].getBoundingClientRect().width;
      const h = items[0].getBoundingClientRect().height;
      box.style.height = h + 'px';
      box.style.width = Math.ceil(w) + 'px';
      track.style.transform = `translate3d(0,${-i * h}px,0)`;
    };

    let i = 0;
    sizeTo(0);
    // Re-measure once webfonts land, otherwise the box is sized from fallback
    // metrics and the word gets clipped.
    if (document.fonts?.ready) document.fonts.ready.then(() => sizeTo(i));
    addEventListener('resize', () => sizeTo(i), { passive: true });

    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let timer = 0;
    const tick = () => {
      i = (i + 1) % items.length;
      sizeTo(i);
    };
    const start = () => {
      clearInterval(timer);
      timer = setInterval(tick, 2400);
    };
    const stop = () => clearInterval(timer);

    start();
    // Do not burn cycles while the tab is hidden or the hero is off screen.
    document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(([e]) => (e.isIntersecting ? start() : stop()), { threshold: 0.05 }).observe(box);
    }
  })();

  (() => {
    const section = document.getElementById('hero');
    const stage = document.getElementById('stage');
    const canvas = document.getElementById('hero-canvas');
    const spot = document.getElementById('hero-spot');
    const content = document.getElementById('hero-content');
    const video = document.getElementById('hero-video');
    if (!section || !stage || !canvas) return;

    const ctx = canvas.getContext('2d', { alpha: true });
    if (!ctx) return;

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const conn = navigator.connection || {};
    const thrifty = conn.saveData === true || (navigator.hardwareConcurrency || 8) <= 4;

    const INK = '27,27,27';
    const CLAY = '180,83,42';

    let w = 0,
      h = 0,
      dpr = 1;
    let particles = [];
    let raf = 0;
    let running = false;
    let t = 0;

    // Pointer, eased so the light trails the cursor rather than snapping.
    const ptr = { x: 0.5, y: 0.42, tx: 0.5, ty: 0.42, active: false };

    function count() {
      if (thrifty) return 40;
      const byArea = Math.round((w * h) / 14000);
      return Math.max(60, Math.min(230, byArea));
    }

    function seed() {
      particles = Array.from({ length: count() }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        px: 0,
        py: 0,
        sp: 0.28 + Math.random() * 0.72,
        // A few strands pick up the accent colour.
        clay: Math.random() < 0.16,
        life: Math.random() * 400,
      }));
      particles.forEach((p) => {
        p.px = p.x;
        p.py = p.y;
      });
    }

    function resize() {
      const r = stage.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, thrifty ? 1 : 2);
      w = Math.max(1, Math.round(r.width));
      h = Math.max(1, Math.round(r.height));
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, w, h);
      seed();
    }

    // Cheap layered-sine flow field. No noise library, no dependency.
    function angleAt(x, y, time) {
      const a = Math.sin(x * 0.0016 + time * 0.22) + Math.cos(y * 0.0021 - time * 0.17);
      const b = Math.sin((x + y) * 0.0011 + time * 0.11);
      return (a + b) * 1.25;
    }

    function step() {
      t += 0.016;

      // Ease the pointer, then hand it to CSS for the light.
      ptr.x += (ptr.tx - ptr.x) * 0.06;
      ptr.y += (ptr.ty - ptr.y) * 0.06;
      if (spot && !reduced) {
        spot.style.setProperty('--mx', (ptr.x * 100).toFixed(2) + '%');
        spot.style.setProperty('--my', (ptr.y * 100).toFixed(2) + '%');
      }

      // Trail decay rather than a hard clear. Slow decay = longer strands.
      ctx.globalCompositeOperation = 'destination-out';
      ctx.fillStyle = 'rgba(0,0,0,0.032)';
      ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = 'source-over';

      const px = ptr.x * w;
      const py = ptr.y * h;
      // Footage underneath means the strands step back out of its way.
      const alpha = video && video.dataset.playing === '1' ? 0.07 : 0.17;

      ctx.lineWidth = 1;
      for (const p of particles) {
        p.px = p.x;
        p.py = p.y;

        let ang = angleAt(p.x, p.y, t);

        // Pointer curl - strands bend around the cursor.
        if (ptr.active) {
          const dx = p.x - px;
          const dy = p.y - py;
          const d2 = dx * dx + dy * dy;
          const R = 240;
          if (d2 < R * R) {
            const d = Math.sqrt(d2) || 1;
            const f = (1 - d / R) * 1.9;
            ang += Math.atan2(dy, dx) * f * 0.5;
          }
        }

        p.x += Math.cos(ang) * p.sp * 1.5;
        p.y += Math.sin(ang) * p.sp * 1.5;

        // Recycle off-screen or aged strands so the field keeps renewing.
        if (++p.life > 520 || p.x < -40 || p.x > w + 40 || p.y < -40 || p.y > h + 40) {
          p.x = Math.random() * w;
          p.y = Math.random() * h;
          p.px = p.x;
          p.py = p.y;
          p.life = 0;
          continue;
        }

        ctx.strokeStyle = `rgba(${p.clay ? CLAY : INK},${p.clay ? alpha * 2.4 : alpha})`;
        ctx.beginPath();
        ctx.moveTo(p.px, p.py);
        ctx.lineTo(p.x, p.y);
        ctx.stroke();
      }

      if (running) raf = requestAnimationFrame(step);
    }

    // Compose a still frame synchronously. Used as the reduced-motion output,
    // and as the first paint so the hero is never blank - including when the
    // page is opened in a background tab, where rAF does not fire at all.
    function still(steps) {
      const wasRunning = running;
      running = false;
      for (let i = 0; i < steps; i++) step();
      running = wasRunning;
    }

    function start() {
      if (reduced) return;
      // Always re-arm. A frame requested while the tab was hidden never
      // arrives, so guarding on `running` alone would strand the loop.
      cancelAnimationFrame(raf);
      running = true;
      raf = requestAnimationFrame(step);
    }

    function stop() {
      running = false;
      cancelAnimationFrame(raf);
      raf = 0;
    }

    // ---- Wiring ----------------------------------------------------------
    resize();

    let rt = 0;
    addEventListener(
      'resize',
      () => {
        clearTimeout(rt);
        rt = setTimeout(() => {
          resize();
          // Resizing clears the canvas, so re-compose rather than flash empty.
          still(reduced ? 240 : 70);
        }, 180);
      },
      { passive: true }
    );

    // Paint something immediately, before any animation frame is involved.
    still(reduced ? 260 : 190);

    if (!reduced) {
      start();
      if (spot) spot.style.opacity = '1';
    }

    // Only animate while the hero is actually on screen.
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(
        ([e]) => {
          if (reduced) return;
          if (e.isIntersecting) start();
          else stop();
        },
        { threshold: 0.02 }
      ).observe(section);
    }
    document.addEventListener('visibilitychange', () => {
      if (reduced) return;
      if (document.hidden) stop();
      else start();
    });

    // Pointer - mouse only. Touch keeps the ambient field.
    if (matchMedia('(hover:hover) and (pointer:fine)').matches) {
      addEventListener(
        'pointermove',
        (e) => {
          const r = stage.getBoundingClientRect();
          ptr.tx = (e.clientX - r.left) / r.width;
          ptr.ty = (e.clientY - r.top) / r.height;
          ptr.active = true;
        },
        { passive: true }
      );
      document.addEventListener('pointerleave', () => {
        ptr.active = false;
        ptr.tx = 0.5;
        ptr.ty = 0.42;
      });
    }

    // Scroll hand-off, rAF-throttled so it never fights the render loop.
    if (content && !reduced) {
      const apply = () => {
        const p = Math.min(1, Math.max(0, window.scrollY / (window.innerHeight || 1)));
        content.style.transform = `translate3d(0,${(p * -70).toFixed(1)}px,0)`;
        content.style.opacity = String(1 - p * 0.85);
      };
      // Coalesce to one frame per scroll burst. Re-requesting rather than
      // holding a flag means a frame that never fires cannot strand this.
      let sraf = 0;
      const onScroll = () => {
        cancelAnimationFrame(sraf);
        sraf = requestAnimationFrame(apply);
      };
      apply();
      addEventListener('scroll', onScroll, { passive: true });
    }

    // Tell the bundled module whether it is allowed to run at all.
    stage.dataset.glAllowed = !reduced && !thrifty ? '1' : '0';

    // Footage is opt-in and lazy: never fetched on save-data or reduced motion.
    if (video && !thrifty && !reduced) {
      const play = () => {
        video.preload = 'auto';
        video.load();
        video.play().then(
          () => {
            video.dataset.playing = '1';
            video.style.opacity = '1';
          },
          () => {
            /* autoplay refused - the canvas already carries the hero */
          }
        );
      };
      if ('requestIdleCallback' in window) requestIdleCallback(play, { timeout: 2200 });
      else setTimeout(play, 900);
    }
  })();
</script>

<!-- Bundled (not inline) so the dynamic import can be code-split: three.js
     ships in its own chunk that is only fetched on devices that will use it. -->
<script>
  (() => {
    const host = document.getElementById('stage');
    const canvas = document.getElementById('hero-gl');
    if (!host || !canvas) return;
    if (host.dataset.glAllowed !== '1') return;

    // Cheap capability probe before pulling down the chunk.
    function hasWebGL() {
      try {
        const c = document.createElement('canvas');
        return !!(c.getContext('webgl2') || c.getContext('webgl'));
      } catch {
        return false;
      }
    }
    if (!hasWebGL()) return;

    const go = () => {
      import('../scripts/hero3d.js')
        .then(({ initHero3D }) => {
          const inst = initHero3D(canvas, host);
          if (inst) host.classList.add('has-gl');
        })
        .catch(() => {
          /* 2D hero already stands on its own */
        });
    };

    if ('requestIdleCallback' in window) requestIdleCallback(go, { timeout: 2500 });
    else setTimeout(go, 1000);
  })();
</script>
