---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatFab from '../components/ChatFab.astro';
import { landings, bySlug } from '../data/landings';
import { company, engagements, intake} from '../data/site';

export function getStaticPaths() {
  return landings.map((l) => ({ params: { slug: l.slug } }));
}

const { slug } = Astro.params;
const page = bySlug(slug!)!;
const related = page.related.map((s) => bySlug(s)!).filter(Boolean);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: page.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const crumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://allaiastudio.com/' },
    { '@type': 'ListItem', position: 2, name: page.eyebrow, item: `https://allaiastudio.com/${page.slug}` },
  ],
};
---

<Base title={page.title} description={page.description} path={`/${page.slug}`}>
  <Header solid />

  <main id="main">
    <!-- HERO -->
    <section class="mx-auto max-w-[90rem] px-6 pb-16 pt-36 sm:px-10 lg:px-14 lg:pt-44">
      <nav aria-label="Breadcrumb" class="label text-ink-300">
        <a href="/" class="transition-colors hover:text-ink-700">Home</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span class="text-ink-500">{page.eyebrow}</span>
      </nav>

      <h1 class="display mt-10 max-w-[18ch] text-[clamp(2.6rem,7.5vw,6.5rem)]">
        {page.h1} <span class="italic text-clay-500">{page.h1Accent}</span>
      </h1>

      <div class="mt-14 grid gap-12 border-t rule pt-12 lg:grid-cols-[1fr_auto] lg:items-start">
        <p class="max-w-2xl text-lg leading-relaxed text-ink-700 sm:text-xl">{page.lede}</p>
        <a
          href="/apply/"
          class="inline-flex shrink-0 items-center justify-center rounded-full bg-ink-900 px-8 py-4 text-sm font-semibold text-bone-50 transition-all hover:-translate-y-0.5 hover:bg-clay-500"
        >
          {intake.ctaPrimary}
        </a>
      </div>
    </section>

    <!-- PAIN -->
    <section class="border-y rule bg-bone-100 py-20 lg:py-28">
      <div class="mx-auto max-w-[90rem] px-6 sm:px-10 lg:px-14">
        <div class="grid gap-14 lg:grid-cols-[0.8fr_1.2fr]">
          <h2 class="display reveal text-[clamp(2rem,4.5vw,3.5rem)]">{page.painTitle}</h2>
          <ul class="border-t rule">
            {
              page.pain.map((p) => (
                <li class="reveal flex items-start gap-5 border-b rule py-6">
                  <span class="mt-2.5 h-1 w-1 shrink-0 rounded-full bg-clay-500" aria-hidden="true" />
                  <span class="text-lg leading-relaxed text-ink-700">{p}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <!-- APPROACH -->
    <section class="mx-auto max-w-[90rem] px-6 py-24 sm:px-10 lg:px-14 lg:py-32">
      <h2 class="display reveal max-w-[14ch] text-[clamp(2.2rem,5vw,4rem)]">{page.approachTitle}</h2>

      <ol class="mt-16 border-t rule">
        {
          page.approach.map((a) => (
            <li class="reveal grid gap-4 border-b rule py-9 md:grid-cols-[6rem_1fr] lg:grid-cols-[8rem_0.9fr_1.4fr] lg:gap-10">
              <span class="label text-clay-500">{a.n}</span>
              <h3 class="display text-2xl lg:text-3xl">{a.title}</h3>
              <p class="max-w-2xl leading-relaxed text-ink-700">{a.body}</p>
            </li>
          ))
        }
      </ol>

      <p class="reveal mt-12 max-w-3xl text-lg leading-relaxed text-ink-500">{page.proof}</p>

      {/* The documented results are all property, so this band only belongs on
          the real estate page - it would over-claim anywhere else. */}
      {
        page.slug === 'real-estate-marketing-philippines' && (
          <a
            href="/case-studies/"
            class="reveal group mt-12 block rounded-3xl bg-ink-900 p-9 text-bone-50 transition-colors hover:bg-ink-700 lg:p-12"
          >
            <p class="label text-clay-400">Eight documented campaigns</p>
            <h3 class="display mt-4 max-w-[20ch] text-2xl lg:text-3xl">
              ₱47.9M in closed condo sales, a ₱50M Makati unit, and cost per message cut from ₱77 to ₱11.
            </h3>
            <span class="mt-7 inline-flex items-center gap-2 text-sm font-semibold">
              Read the case studies
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </span>
          </a>
        )
      }
    </section>

    <!-- ENGAGEMENTS -->
    <section class="border-y rule bg-ink-900 py-20 text-bone-50 lg:py-28">
      <div class="mx-auto max-w-[90rem] px-6 sm:px-10 lg:px-14">
        <h2 class="display reveal text-[clamp(2rem,4.5vw,3.5rem)]">
          Three ways <span class="italic text-bone-50/50">to work together.</span>
        </h2>
        <div class="mt-14 grid gap-x-12 gap-y-px border-t border-bone-50/15 md:grid-cols-3">
          {
            engagements.map((e) => (
              <div class="reveal border-b border-bone-50/15 py-8">
                <p class="label text-clay-400">{e.forWho}</p>
                <h3 class="display mt-3 text-3xl">{e.name}</h3>
                <p class="mt-3 text-sm leading-relaxed text-bone-50/55">{e.body}</p>
              </div>
            ))
          }
        </div>
        <a href="/engagements/" class="mt-12 inline-flex items-center gap-2 text-sm font-semibold text-bone-50 underline underline-offset-4 transition-colors hover:text-clay-400">
          See what each one includes
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mx-auto max-w-[90rem] px-6 py-24 sm:px-10 lg:px-14 lg:py-32">
      <div class="grid gap-14 lg:grid-cols-[0.6fr_1.4fr]">
        <h2 class="display reveal text-[clamp(2rem,4.5vw,3.5rem)] lg:sticky lg:top-32 lg:h-fit">
          Questions<br /><span class="italic text-ink-300">worth asking.</span>
        </h2>
        <div class="border-t rule">
          {
            page.faqs.map((f) => (
              <details class="reveal group border-b rule py-7">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-8 text-lg font-medium [&::-webkit-details-marker]:hidden">
                  {f.q}
                  <span class="mt-2 h-px w-6 shrink-0 bg-ink-900 transition-transform duration-300 group-open:rotate-90" aria-hidden="true" />
                </summary>
                <p class="mt-5 max-w-2xl pr-12 leading-relaxed text-ink-700">{f.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- RELATED - real internal linking, not a nav dump -->
    {
      related.length > 0 && (
        <section class="mx-auto max-w-[90rem] px-6 pb-24 sm:px-10 lg:px-14 lg:pb-32">
          <p class="label reveal text-ink-500">Related</p>
          <div class="mt-8 grid gap-px border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] md:grid-cols-2">
            {related.map((r) => (
              <a href={`/${r.slug}`} class="reveal group bg-bone-50 p-9 transition-colors hover:bg-bone-100 lg:p-12">
                <p class="label text-clay-500">{r.eyebrow}</p>
                <h3 class="display mt-4 text-2xl lg:text-3xl">
                  {r.h1} <span class="italic">{r.h1Accent}</span>
                </h3>
                <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-ink-900">
                  Read more
                  <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <!-- CTA -->
    <section class="px-6 pb-24 sm:px-10 lg:px-14 lg:pb-32">
      <div class="mx-auto max-w-[90rem] border-y rule py-20 text-center lg:py-24">
        <h2 class="display reveal mx-auto max-w-[16ch] text-[clamp(2.2rem,5.5vw,4.5rem)]">
          Tell us what you're <span class="italic text-clay-500">trying to grow.</span>
        </h2>
        <div class="reveal mt-10 flex flex-col justify-center gap-3 sm:flex-row">
          <a href="/apply/" class="inline-flex items-center justify-center rounded-full bg-ink-900 px-9 py-4 text-sm font-semibold text-bone-50 transition-all hover:-translate-y-0.5 hover:bg-clay-500">
            {intake.ctaPrimary}
          </a>
          <a href={`tel:${company.phoneHref}`} class="inline-flex items-center justify-center rounded-full border rule px-9 py-4 text-sm font-semibold transition-colors hover:border-ink-900">
            {company.phone}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <ChatFab />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(crumbs)} />
</Base>
