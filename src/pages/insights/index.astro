---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ChatFab from '../../components/ChatFab.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const fmt = (d: Date) => d.toLocaleDateString('en-PH', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Base
  title="Insights | Meta Ads, Property & Recruitment Marketing in the Philippines"
  description="Practical writing on running Meta ads in the Philippines - budgets, lead quality, property campaigns, clinic advertising rules and recruitment."
  path="/insights"
>
  <Header solid />

  <main id="main">
    <section class="mx-auto max-w-[90rem] px-6 pb-16 pt-36 sm:px-10 lg:px-14 lg:pt-44">
      <nav aria-label="Breadcrumb" class="label text-ink-300">
        <a href="/" class="transition-colors hover:text-ink-700">Home</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span class="text-ink-500">Insights</span>
      </nav>

      <h1 class="display mt-10 max-w-[16ch] text-[clamp(2.6rem,7.5vw,6.5rem)]">
        What we've learned <span class="italic text-clay-500">spending other people's money.</span>
      </h1>

      <p class="mt-12 max-w-2xl border-t rule pt-12 text-lg leading-relaxed text-ink-700 sm:text-xl">
        No listicles and no growth-hacking. Just what actually happens when you run campaigns for Philippine
        businesses, including the parts that go wrong.
      </p>
    </section>

    <section class="mx-auto max-w-[90rem] px-6 pb-24 sm:px-10 lg:px-14 lg:pb-32">
      <ul class="border-t rule">
        {
          posts.map((post) => (
            <li class="reveal border-b rule">
              <a href={`/insights/${post.id}/`} class="group grid gap-4 py-9 md:grid-cols-[10rem_1fr] lg:grid-cols-[12rem_1fr_auto] lg:gap-12 lg:py-11">
                <div class="label text-clay-500">{post.data.topic}</div>

                <div>
                  <h2 class="display text-2xl transition-colors group-hover:text-clay-600 lg:text-3xl">
                    {post.data.title}
                  </h2>
                  <p class="mt-3 max-w-2xl leading-relaxed text-ink-700">{post.data.description}</p>
                </div>

                <time datetime={post.data.date.toISOString()} class="text-sm text-ink-300 lg:pt-2 lg:text-right">
                  {fmt(post.data.date)}
                </time>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>

  <Footer />
  <ChatFab />
</Base>
