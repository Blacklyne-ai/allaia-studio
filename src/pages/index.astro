---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatFab from '../components/ChatFab.astro';
import HeroCinematic from '../components/HeroCinematic.astro';
import WorkWall from '../components/WorkWall.astro';
import MethodSticky from '../components/MethodSticky.astro';
import {
  company, pillars, services, sectors,
  engagements, engagementTerms, principles, faqs,
  testimonials, testimonialsVerified,
} from '../data/site';

const chatHref = company.messenger || `tel:${company.phoneHref}`;
const showTestimonials = testimonialsVerified && testimonials.length > 0;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title="Allaia Studio | Growth & Marketing Studio in Manila"
  description="Manila growth studio running Meta ads, recruitment campaigns and AI lead response for Philippine businesses. Real estate, clinics, food, insurance. Daily monitoring, monthly ROI reporting."
  path="/"
>
  <Header />

  <main id="main">
    <HeroCinematic />

    <!-- SECTORS MARQUEE -->
    <section id="sectors" class="marquee overflow-hidden border-y rule bg-bone-100 py-8">
      <h2 class="sr-only">Sectors we have delivered work in</h2>
      <div class="marquee-track flex w-max items-center gap-12 whitespace-nowrap">
        {
          [0, 1].map(() => (
            <>
              {sectors.map((s) => (
                <span class="flex items-center gap-12">
                  <span class={`display text-2xl sm:text-3xl ${s.flagship ? 'text-ink-900' : 'text-ink-300'}`}>
                    {s.name}
                  </span>
                  <span class="h-1 w-1 shrink-0 rounded-full bg-clay-500" aria-hidden="true" />
                </span>
              ))}
            </>
          ))
        }
      </div>
    </section>

    <!-- PILLARS -->
    <section id="services" class="mx-auto max-w-[90rem] px-6 py-24 sm:px-10 lg:px-14 lg:py-36">
      <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
        <div class="reveal">
          <p class="label text-clay-500">What we do</p>
          <h2 class="display mt-6 text-[clamp(2.5rem,6vw,5rem)]">
            Three things,<br /><span class="italic">done properly.</span>
          </h2>
        </div>
        <p class="reveal max-w-xl text-lg leading-relaxed text-ink-700 lg:pb-3">
          Most agencies sell you a list. These are the three that move the number, and everything else exists to
          support them.
        </p>
      </div>

      <div class="mt-20 grid gap-px overflow-hidden border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] md:grid-cols-3">
        {
          pillars.map((p) => (
            <article class="reveal group bg-bone-50 p-9 transition-colors duration-500 hover:bg-bone-100 lg:p-12">
              <span class="display text-6xl text-clay-500/30 transition-colors duration-500 group-hover:text-clay-500">
                {p.n}
              </span>
              <h3 class="display mt-8 text-3xl lg:text-4xl">{p.title}</h3>
              <p class="mt-5 text-[0.95rem] leading-relaxed text-ink-700">{p.body}</p>
            </article>
          ))
        }
      </div>

      <!-- Everything else -->
      <div class="mt-20">
        <p class="label reveal text-ink-500">Everything else, in-house</p>
        <div class="mt-8 grid gap-x-12 gap-y-px border-t rule sm:grid-cols-2 lg:grid-cols-3">
          {
            services.map((s) => (
              <div class="reveal border-b rule py-6">
                <h3 class="text-base font-semibold tracking-tight text-ink-900">{s.title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-ink-500">{s.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <WorkWall />

    <MethodSticky />

    <!-- ENGAGEMENTS -->
    <section id="engagements" class="mx-auto max-w-[90rem] px-6 py-24 sm:px-10 lg:px-14 lg:py-36">
      <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
        <div class="reveal">
          <p class="label text-clay-500">Engagements</p>
          <h2 class="display mt-6 text-[clamp(2.5rem,6vw,5rem)]">
            Three ways<br /><span class="italic">to work together.</span>
          </h2>
        </div>
        <p class="reveal max-w-xl text-lg leading-relaxed text-ink-700 lg:pb-3">
          Every engagement includes a dedicated account manager, daily monitoring and monthly reporting. Cost depends
          on scope - tell us what you're working with and we'll quote it properly.
        </p>
      </div>

      <div class="mt-20 grid gap-px border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] lg:grid-cols-3">
        {
          engagements.map((e) => (
            <article class={`reveal flex flex-col p-9 lg:p-12 ${e.featured ? 'bg-ink-900 text-bone-50' : 'bg-bone-50'}`}>
              <div class="flex items-baseline justify-between gap-4">
                <p class={`label ${e.featured ? 'text-clay-400' : 'text-ink-500'}`}>{e.forWho}</p>
                {e.featured && <span class="label text-bone-50/40">Most chosen</span>}
              </div>

              <h3 class="display mt-5 text-4xl lg:text-5xl">{e.name}</h3>
              <p class={`mt-5 text-[0.95rem] leading-relaxed ${e.featured ? 'text-bone-50/60' : 'text-ink-700'}`}>
                {e.body}
              </p>

              <ul class={`mt-9 space-y-3 border-t pt-8 ${e.featured ? 'border-bone-50/15' : 'rule'}`}>
                {e.features.map((f) => (
                  <li class={`flex items-baseline gap-3 text-sm ${e.featured ? 'text-bone-50/75' : 'text-ink-700'}`}>
                    <span class={`h-1 w-1 shrink-0 rounded-full ${e.featured ? 'bg-bone-50/40' : 'bg-ink-300'}`} aria-hidden="true" />
                    {f}
                  </li>
                ))}
                {e.extras.map((f) => (
                  <li class={`flex items-baseline gap-3 text-sm font-semibold ${e.featured ? 'text-bone-50' : 'text-ink-900'}`}>
                    <span class="h-1 w-1 shrink-0 rounded-full bg-clay-500" aria-hidden="true" />
                    {f}
                  </li>
                ))}
              </ul>

              <a
                href={chatHref}
                class={`mt-10 inline-flex items-center justify-center rounded-full px-7 py-3.5 text-sm font-semibold transition-all hover:-translate-y-0.5 ${
                  e.featured ? 'bg-bone-50 text-ink-900 hover:bg-clay-400' : 'bg-ink-900 text-bone-50 hover:bg-clay-500'
                }`}
              >
                Get a quote
              </a>
            </article>
          ))
        }
      </div>

      <ul class="reveal mt-12 grid gap-x-12 gap-y-4 sm:grid-cols-2">
        {
          engagementTerms.map((t) => (
            <li class="flex items-baseline gap-3 text-sm leading-relaxed text-ink-500">
              <span class="h-1 w-1 shrink-0 rounded-full bg-clay-500" aria-hidden="true" />
              {t}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- STUDIO -->
    <section id="studio" class="border-y rule bg-bone-100 py-24 lg:py-36">
      <div class="mx-auto max-w-[90rem] px-6 sm:px-10 lg:px-14">
        <div class="grid gap-16 lg:grid-cols-[0.9fr_1.1fr]">
          <div class="reveal lg:sticky lg:top-32 lg:self-start">
            <p class="label text-clay-500">The studio</p>
            <h2 class="display mt-6 text-[clamp(2.5rem,6vw,5rem)]">
              Small team.<br /><span class="italic">Deep in real estate.</span>
            </h2>
            <p class="mt-8 max-w-lg text-lg leading-relaxed text-ink-700">
              We're a growth studio, not an ad-buying desk. The same people handle the strategy, the creative, the
              systems and the reporting - which is why nothing gets lost in a handover. Our deepest body of work is
              in Philippine real estate, where trust is what actually closes the deal.
            </p>
            <a
              href={chatHref}
              class="mt-10 inline-flex items-center gap-2.5 rounded-full bg-ink-900 px-8 py-4 text-sm font-semibold text-bone-50 transition-all hover:-translate-y-0.5 hover:bg-clay-500"
            >
              Start a conversation
            </a>
          </div>

          <div class="grid gap-px border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] sm:grid-cols-2">
            {
              principles.map((p) => (
                <article class="reveal bg-bone-100 p-9">
                  <h3 class="display text-2xl">{p.title}</h3>
                  <p class="mt-4 text-sm leading-relaxed text-ink-700">{p.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    {
      showTestimonials && (
        <section class="mx-auto max-w-[90rem] px-6 py-24 sm:px-10 lg:px-14 lg:py-36">
          <p class="label reveal text-clay-500">Client words</p>
          <div class="mt-12 grid gap-px border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] md:grid-cols-2 lg:grid-cols-3">
            {testimonials.map((t) => (
              <figure class="reveal bg-bone-50 p-9">
                <blockquote class="display text-2xl leading-snug">{t.quote}</blockquote>
                <figcaption class="mt-6 border-t rule pt-5 text-sm">
                  <span class="block font-semibold text-ink-900">{t.author}</span>
                  <span class="block text-ink-500">{t.role}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        </section>
      )
    }

    <!-- FAQ -->
    <section class="mx-auto max-w-[90rem] px-6 py-24 sm:px-10 lg:px-14 lg:py-36">
      <div class="grid gap-16 lg:grid-cols-[0.6fr_1.4fr]">
        <div class="reveal lg:sticky lg:top-32 lg:self-start">
          <p class="label text-clay-500">Questions</p>
          <h2 class="display mt-6 text-[clamp(2.5rem,5vw,4rem)]">
            Before you<br /><span class="italic">get in touch.</span>
          </h2>
        </div>

        <div class="border-t rule">
          {
            faqs.map((f) => (
              <details class="reveal group border-b rule py-7">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-8 text-lg font-medium text-ink-900 [&::-webkit-details-marker]:hidden">
                  {f.q}
                  <span class="mt-2 h-px w-6 shrink-0 bg-ink-900 transition-transform duration-300 group-open:rotate-90" aria-hidden="true" />
                </summary>
                <p class="mt-5 max-w-2xl pr-12 leading-relaxed text-ink-700">{f.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 pb-24 sm:px-10 lg:px-14 lg:pb-36">
      <div class="mx-auto max-w-[90rem] border-y rule py-24 text-center lg:py-32">
        <h2 class="display reveal mx-auto max-w-[16ch] text-[clamp(2.5rem,7vw,6rem)]">
          Tell us what you're<br /><span class="italic text-clay-500">trying to grow.</span>
        </h2>
        <p class="reveal mx-auto mt-8 max-w-xl text-lg leading-relaxed text-ink-700">
          Send a message and you'll get a straight answer on whether we can help, and what it would take. If we're
          not the right fit we'll say so.
        </p>
        <div class="reveal mt-12 flex flex-col justify-center gap-3 sm:flex-row">
          <a
            href={chatHref}
            class="inline-flex items-center justify-center rounded-full bg-ink-900 px-9 py-4 text-sm font-semibold text-bone-50 transition-all hover:-translate-y-0.5 hover:bg-clay-500"
          >
            Start a conversation
          </a>
          <a
            href={`tel:${company.phoneHref}`}
            class="inline-flex items-center justify-center rounded-full border rule px-9 py-4 text-sm font-semibold text-ink-900 transition-colors hover:border-ink-900"
          >
            {company.phone}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <ChatFab />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>
