---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatFab from '../components/ChatFab.astro';
import HeroCinematic from '../components/HeroCinematic.astro';
import SectorBand from '../components/SectorBand.astro';
import PageCta from '../components/PageCta.astro';
import { pillars, testimonials, testimonialsVerified, caseStudies } from '../data/site';

// Two gates: the master flag, and per-person consent.
const consented = testimonials.filter((t) => t.consent);
const property = consented.filter((t) => t.sector === 'Real Estate');
const other = consented.filter((t) => t.sector !== 'Real Estate');
// Alternate until one list runs out, then append the remainder, so the first
// row shows range rather than five property quotes in a row.
const interleaved: typeof consented = [];
for (let p = 0, o = 0; p < property.length || o < other.length; ) {
  if (p < property.length) interleaved.push(property[p++]);
  if (o < other.length) interleaved.push(other[o++]);
}
// The home page shows a selection; the rest live on their own pages.
const approved = interleaved.slice(0, 6);
const showTestimonials = testimonialsVerified && approved.length > 0;

const featured = caseStudies.filter((c) => c.featured).slice(0, 3);

// Where each pillar sends you. The home page introduces, the pages explain.
const pillarLinks = ['/services/', '/work/', '/method/'];
---

<Base
  title="Allaia Studio | Growth & Marketing Studio in Manila"
  description="More bookings, more leads, more sales. A Manila growth studio running ads, SEO, websites, recruitment and AI systems for Philippine businesses across property, clinics, food, insurance and more."
  path="/"
>
  <Header />

  <main id="main">
    <HeroCinematic />

    <SectorBand />

    <!-- What we do - a doorway to /services, not the whole thing -->
    <section class="mx-auto max-w-[90rem] px-6 py-24 sm:px-10 lg:px-14 lg:py-32">
      <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
        <div class="reveal">
          <p class="label text-clay-500">What we do</p>
          <h2 class="display mt-6 text-[clamp(2.5rem,6vw,5rem)]">
            Three outcomes.<br /><span class="italic">Everything serves them.</span>
          </h2>
        </div>
        <p class="reveal max-w-xl text-lg leading-relaxed text-ink-700 lg:pb-3">
          We start from the number you need to move, then use whichever mix of ads, search, systems and design
          actually moves it.
        </p>
      </div>

      <div class="mt-16 grid gap-px border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] md:grid-cols-3">
        {
          pillars.map((p, i) => (
            <a
              href={pillarLinks[i]}
              class="reveal group flex flex-col bg-bone-50 p-9 transition-colors duration-500 hover:bg-bone-100 lg:p-12"
            >
              <span class="display text-6xl text-clay-500/30 transition-colors duration-500 group-hover:text-clay-500">
                {p.n}
              </span>
              <h3 class="display mt-8 text-3xl lg:text-4xl">{p.title}</h3>
              <p class="mt-5 text-[0.95rem] leading-relaxed text-ink-700">{p.body}</p>
              <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-ink-900">
                {['See the services', 'See the work', 'See the method'][i]}
                <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Results preview -->
    <section class="border-y rule bg-ink-900 py-20 text-bone-50 lg:py-28">
      <div class="mx-auto max-w-[90rem] px-6 sm:px-10 lg:px-14">
        <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
          <div>
            <p class="label text-clay-400">Documented results - real estate</p>
            <h2 class="display mt-6 text-[clamp(2rem,4.5vw,3.5rem)]">
              What the work<br /><span class="italic text-bone-50/50">actually returned.</span>
            </h2>
          </div>
          <p class="max-w-xl leading-relaxed text-bone-50/60 lg:pb-3">
            Figures from the original campaign reporting. Real estate is where our documented numbers are - the
            portfolio spans nine sectors.
          </p>
        </div>

        <div class="mt-14 grid gap-px border border-bone-50/15 bg-bone-50/15 md:grid-cols-3">
          {
            featured.map((c) => (
              <a href={`/case-studies/#${c.slug}`} class="group bg-ink-900 p-8 transition-colors hover:bg-ink-700/40 lg:p-10">
                <p class="label text-clay-400">{c.sector}</p>
                <p class="display mt-5 text-4xl text-clay-400 lg:text-5xl">{c.metrics[0].value}</p>
                <p class="mt-2 text-xs text-bone-50/50">{c.metrics[0].label}</p>
                <h3 class="mt-6 text-lg leading-snug">{c.title}</h3>
                <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold">
                  Read it
                  <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </span>
              </a>
            ))
          }
        </div>

        <a href="/case-studies/" class="mt-12 inline-flex items-center gap-2 text-sm font-semibold underline underline-offset-4 transition-colors hover:text-clay-400">
          All eight case studies
        </a>
      </div>
    </section>

    <!-- Testimonials -->
    {
      showTestimonials && (
        <section class="mx-auto max-w-[90rem] px-6 py-24 sm:px-10 lg:px-14 lg:py-32">
          <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
            <div class="reveal">
              <p class="label text-clay-500">Client words</p>
              <h2 class="display mt-6 text-[clamp(2.5rem,6vw,5rem)]">
                Their words,<br /><span class="italic">not ours.</span>
              </h2>
            </div>
            <p class="reveal max-w-xl text-lg leading-relaxed text-ink-700 lg:pb-3">
              Straight from Messenger, exactly as they were sent, across property, hospitality, retail, furniture and
              motors. Published with each client's permission.
            </p>
          </div>

          <div class="mt-16 grid gap-px border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] md:grid-cols-2 lg:grid-cols-3">
            {approved.map((t) => (
              <figure class="reveal flex flex-col bg-bone-50 p-9">
                <p class="label mb-5 text-clay-500">{t.sector}</p>
                <blockquote class="display text-2xl leading-snug">{t.quote}</blockquote>
                <figcaption class="mt-6 border-t rule pt-5 text-sm">
                  <span class="block font-semibold text-ink-900">{t.author}</span>
                  <span class="block text-ink-500">{t.role}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        </section>
      )
    }

    <PageCta />
  </main>

  <Footer />
  <ChatFab />
</Base>
