---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ChatFab from '../../components/ChatFab.astro';
import PageHead from '../../components/PageHead.astro';
import { intake, company, chatHref, engagements } from '../../data/site';
---

<Base
  title="Apply | Allaia Studio Works by Application"
  description="Allaia Studio takes a limited number of clients and screens for fit. Apply, get a straight answer within a few days, and start on the next intake or join the waitlist."
  path="/apply/"
>
  <Header solid />

  <main id="main">
    <PageHead
      crumb="Apply"
      eyebrow="Intake"
      title="We work by"
      accent="application."
      lede="Not because it sounds exclusive. Because a campaign only works when the offer, the margin and the capacity to answer enquiries are all already in place - and if they are not, taking your money would waste it."
    />

    <!-- Status -->
    <section class="mx-auto max-w-[90rem] px-6 pb-16 sm:px-10 lg:px-14">
      <div class="flex flex-wrap items-center gap-4 rounded-2xl border border-clay-500/30 bg-clay-500/5 px-7 py-5">
        <span class="relative flex h-2.5 w-2.5 shrink-0">
          <span class="absolute inline-flex h-full w-full rounded-full bg-clay-500/60"></span>
          <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-clay-500"></span>
        </span>
        <p class="text-sm font-semibold text-clay-600">{intake.status}</p>
      </div>
    </section>

    <!-- The four steps -->
    <section class="mx-auto max-w-[90rem] px-6 pb-20 sm:px-10 lg:px-14">
      <h2 class="display text-[clamp(2rem,4.5vw,3.4rem)]">
        How it <span class="italic text-clay-500">actually goes.</span>
      </h2>

      <ol class="mt-12 grid gap-px border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] md:grid-cols-2 lg:grid-cols-4">
        {
          intake.screening.map((s) => (
            <li class="reveal bg-bone-50 p-8 lg:p-9">
              <span class="display text-4xl text-clay-500/35">{s.n}</span>
              <h3 class="display mt-6 text-2xl">{s.title}</h3>
              <p class="mt-4 text-sm leading-relaxed text-ink-700">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <!-- When we say no -->
    <section class="border-y rule bg-ink-900 py-20 text-bone-50 lg:py-24">
      <div class="mx-auto max-w-[90rem] px-6 sm:px-10 lg:px-14">
        <div class="grid gap-14 lg:grid-cols-[0.9fr_1.1fr]">
          <div>
            <p class="label text-clay-400">The screen</p>
            <h2 class="display mt-6 text-[clamp(2rem,4.5vw,3.4rem)]">
              When we<br /><span class="italic text-bone-50/50">say no.</span>
            </h2>
            <p class="mt-8 max-w-md leading-relaxed text-bone-50/60">
              We turn work away regularly, and it is the most useful thing we do for those businesses. Advertising
              magnifies whatever is already there - including the problems.
            </p>
          </div>

          <ul class="border-t border-bone-50/15">
            {
              intake.declineReasons.map((r) => (
                <li class="flex items-baseline gap-4 border-b border-bone-50/15 py-6 leading-relaxed text-bone-50/75">
                  <span class="h-1 w-1 shrink-0 rounded-full bg-clay-400" aria-hidden="true" />
                  {r}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <!-- What you'd be applying for -->
    <section class="mx-auto max-w-[90rem] px-6 py-20 sm:px-10 lg:px-14">
      <p class="label text-ink-500">What you would be applying for</p>
      <div class="mt-8 grid gap-x-12 gap-y-px border-t rule md:grid-cols-3">
        {
          engagements.map((e) => (
            <div class="border-b rule py-7">
              <p class="label text-clay-500">{e.forWho}</p>
              <h3 class="display mt-3 text-2xl">{e.name}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-500">{e.body}</p>
            </div>
          ))
        }
      </div>
      <a href="/engagements/" class="mt-8 inline-flex items-center gap-2 text-sm font-semibold underline underline-offset-4 hover:text-clay-600">
        See what each one includes
      </a>
    </section>

    <!-- Apply -->
    <section class="px-6 pb-24 sm:px-10 lg:px-14">
      <div class="mx-auto max-w-[90rem] border-y rule py-20 text-center">
        <p class="label text-clay-500">Applications</p>
        <h2 class="display mx-auto mt-6 max-w-[18ch] text-[clamp(2rem,5vw,4rem)]">
          Send us four things and <span class="italic text-clay-500">we'll tell you straight.</span>
        </h2>

        <ul class="mx-auto mt-10 max-w-md space-y-2.5 text-left text-sm text-ink-700">
          <li class="flex items-baseline gap-3">
            <span class="h-1 w-1 shrink-0 rounded-full bg-clay-500" aria-hidden="true"></span>What you sell, and at what price
          </li>
          <li class="flex items-baseline gap-3">
            <span class="h-1 w-1 shrink-0 rounded-full bg-clay-500" aria-hidden="true"></span>What you are spending on ads now, if anything
          </li>
          <li class="flex items-baseline gap-3">
            <span class="h-1 w-1 shrink-0 rounded-full bg-clay-500" aria-hidden="true"></span>How many customers a month you can actually service
          </li>
          <li class="flex items-baseline gap-3">
            <span class="h-1 w-1 shrink-0 rounded-full bg-clay-500" aria-hidden="true"></span>Who answers the enquiries, and how fast
          </li>
        </ul>

        <div class="mt-12 flex flex-col justify-center gap-3 sm:flex-row">
          <a
            href={chatHref}
            class="inline-flex items-center justify-center rounded-full bg-ink-900 px-9 py-4 text-sm font-semibold text-bone-50 transition-all hover:-translate-y-0.5 hover:bg-clay-500"
          >
            {intake.ctaPrimary}
          </a>
          <a
            href={`mailto:${company.email}?subject=Application%20-%20Allaia%20Studio`}
            class="inline-flex items-center justify-center rounded-full border rule px-9 py-4 text-sm font-semibold transition-colors hover:border-ink-900"
          >
            Apply by email
          </a>
        </div>

        <p class="mx-auto mt-8 max-w-md text-xs leading-relaxed text-ink-500">
          No pitch deck required and no obligation. If we are full you go on the waitlist with a realistic date, not
          a holding message.
        </p>
      </div>
    </section>
  </main>

  <Footer />
  <ChatFab />
</Base>
