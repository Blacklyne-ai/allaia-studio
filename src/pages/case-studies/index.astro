---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ChatFab from '../../components/ChatFab.astro';
import PageCta from '../../components/PageCta.astro';
import { caseStudies } from '../../data/site';
---

<Base
  title="Real Estate Facebook Ads Case Studies | Philippines"
  description="Eight documented property campaigns from the Philippines - ₱47.9M in closed condo sales, a ₱50M Makati commercial unit, cost per message cut from ₱77 to ₱11, 361 inquiries at ₱41.59."
  path="/case-studies/"
>
  <Header solid />

  <main id="main">
    <section class="mx-auto max-w-[90rem] px-6 pb-16 pt-36 sm:px-10 lg:px-14 lg:pt-44">
      <nav aria-label="Breadcrumb" class="label text-ink-300">
        <a href="/" class="transition-colors hover:text-ink-700">Home</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span class="text-ink-500">Case studies</span>
      </nav>

      <p class="label mt-10 text-clay-500">Real estate</p>
      <h1 class="display mt-5 max-w-[16ch] text-[clamp(2.6rem,7.5vw,6.5rem)]">
        Eight property campaigns, <span class="italic text-clay-500">with the receipts.</span>
      </h1>

      <div class="mt-12 grid gap-10 border-t rule pt-12 lg:grid-cols-[1.2fr_1fr] lg:gap-16">
        <p class="max-w-2xl text-lg leading-relaxed text-ink-700 sm:text-xl">
          What the brief was, what we ran, and what it returned. Where a figure is an estimate rather than a
          confirmed number, it says so.
        </p>

        <aside class="border-l-2 border-clay-500/40 pl-6">
          <p class="label text-ink-500">Why these are all property</p>
          <p class="mt-4 text-sm leading-relaxed text-ink-700">
            Real estate is where our documented numbers are - the deepest body of work we have, and the sector where
            clients track commission closely enough to report it back.
          </p>
          <p class="mt-3 text-sm leading-relaxed text-ink-700">
            We run campaigns across nine sectors. The creative for clinics, dental, food service, insurance,
            automotive, travel and more is in the <a href="/work/" class="font-semibold text-ink-900 underline underline-offset-4 hover:text-clay-600">portfolio</a>.
          </p>
        </aside>
      </div>
    </section>

    <!-- Index -->
    <section class="mx-auto max-w-[90rem] px-6 pb-20 sm:px-10 lg:px-14">
      <ul class="border-t rule">
        {
          caseStudies.map((c) => (
            <li class="reveal border-b rule">
              <a
                href={`/case-studies/${c.slug}/`}
                class="group grid gap-6 py-9 md:grid-cols-[4rem_1fr] lg:grid-cols-[4rem_1.4fr_auto] lg:gap-12 lg:py-11"
              >
                <span class="display text-3xl text-clay-500/35 transition-colors group-hover:text-clay-500">{c.n}</span>

                <div>
                  <p class="label text-clay-500">{c.sector}</p>
                  <h2 class="display mt-3 text-2xl transition-colors group-hover:text-clay-600 lg:text-3xl">
                    {c.title}
                  </h2>
                  {c.period && <p class="mt-3 text-sm text-ink-500">{c.period}</p>}
                </div>

                <div class="lg:text-right">
                  <p class="display text-3xl text-ink-900 lg:text-4xl">{c.metrics[0].value}</p>
                  <p class="mt-1.5 text-xs text-ink-500">{c.metrics[0].label}</p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Provenance -->
    <section class="border-y rule bg-bone-100 py-16">
      <div class="mx-auto max-w-[52rem] px-6 sm:px-10">
        <p class="label text-ink-500">About these results</p>
        <div class="mt-6 space-y-4 text-sm leading-relaxed text-ink-700">
          <p>
            These campaigns were delivered by the same team, under the studio's previous name, Winnify Ads. Figures
            are reproduced from the original campaign reporting.
          </p>
          <p>
            Commission figures are what the client earned, not studio revenue. Where commission was estimated from
            standard rates rather than confirmed, the case study says so and the lower bound is used.
          </p>
          <p>
            Past performance is not a prediction. Results depend on your market, your offer, your price point and
            your budget, and property commission structures vary.
          </p>
        </div>
      </div>
    </section>

    <PageCta title="Want numbers like these" accent="on your account?" />
  </main>

  <Footer />
  <ChatFab />
</Base>
