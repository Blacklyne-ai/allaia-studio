---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ChatFab from '../../components/ChatFab.astro';
import PageHead from '../../components/PageHead.astro';
import PageCta from '../../components/PageCta.astro';
import { pillars, services, chatHref } from '../../data/site';
import { landings } from '../../data/landings';
---

<Base
  title="Services | Ads, SEO, Websites, Recruitment & AI Systems"
  description="What Allaia Studio does: paid social, Google search, SEO, websites, recruitment campaigns and AI systems - run as one system by one team for Philippine businesses."
  path="/services/"
>
  <Header solid />

  <main id="main">
    <PageHead
      crumb="Services"
      eyebrow="What we do"
      title="Three outcomes."
      accent="Everything serves them."
      lede="Most agencies sell you a channel and leave you to work out what it was for. We start from the number you need to move, then use whichever mix of ads, search, systems and design actually moves it."
    />

    <!-- Pillars -->
    <section class="mx-auto max-w-[90rem] px-6 pb-20 sm:px-10 lg:px-14">
      <div class="grid gap-px overflow-hidden border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] md:grid-cols-3">
        {
          pillars.map((p) => (
            <article class="reveal group bg-bone-50 p-9 transition-colors duration-500 hover:bg-bone-100 lg:p-12">
              <span class="display text-6xl text-clay-500/30 transition-colors duration-500 group-hover:text-clay-500">
                {p.n}
              </span>
              <h2 class="display mt-8 text-3xl lg:text-4xl">{p.title}</h2>
              <p class="mt-5 text-[0.95rem] leading-relaxed text-ink-700">{p.body}</p>
              <p class="mt-7 border-t rule pt-5 text-xs leading-relaxed text-ink-500">{p.through}</p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Everything else -->
    <section class="mx-auto max-w-[90rem] px-6 pb-20 sm:px-10 lg:px-14">
      <p class="label reveal text-ink-500">Everything else, in-house</p>
      <div class="mt-8 grid gap-x-14 gap-y-px border-t rule sm:grid-cols-2">
        {
          services.map((s) => (
            <div class="reveal border-b rule py-6">
              <h3 class="text-base font-semibold tracking-tight text-ink-900">{s.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink-500">{s.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Deep dives -->
    <section class="border-y rule bg-bone-100 py-20 lg:py-24">
      <div class="mx-auto max-w-[90rem] px-6 sm:px-10 lg:px-14">
        <p class="label text-ink-500">Go deeper</p>
        <div class="mt-8 grid gap-px border rule bg-[color-mix(in_oklab,var(--color-ink-900)_12%,transparent)] md:grid-cols-2">
          {
            landings.map((l) => (
              <a href={`/${l.slug}`} class="group bg-bone-100 p-9 transition-colors hover:bg-bone-50 lg:p-11">
                <p class="label text-clay-500">{l.eyebrow}</p>
                <h3 class="display mt-4 text-2xl lg:text-3xl">
                  {l.h1} <span class="italic">{l.h1Accent}</span>
                </h3>
                <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold">
                  Read more
                  <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <PageCta title="Not sure which of these you need?" accent="Ask us." />
  </main>

  <Footer />
  <ChatFab />
</Base>
